<!--
	@file Console/ConsoleWindow.xaml
	@author LinhengXilan
    @version 0.0.0.22
    @date 2025-6-3
-->

<Window x:Class="Editor.Console.ConsoleWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:Editor.Console"
		mc:Ignorable="d"
		Title="ConsoleWindow"
		WindowStyle="None" AllowsTransparency="True"
        MinWidth="640" MinHeight="480">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <local:ConsoleWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="#2C2C2C"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#2C2C2C"/>
        </Style>
        <Style TargetType="Grid">
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
    </Window.Resources>

    <Grid>
		<Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       WindowChrome.IsHitTestVisibleInChrome="True"
                       Text="控制台"
                       VerticalAlignment="Center" Margin="5, 0 , 0, 0"
                       MouseLeftButtonDown="MouseDrag"/>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="40" Background="#00FF00"
                        Click="MinimizationButtonClicked"/>
                <Button Width="40" Background="#FFFF88"
                        Click="MaximizationButtonClicked"/>
                <Button Width="40" Background="#FF0000"
                        Click="CloseButtonClicked"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1"/>
	</Grid>
</Window>
