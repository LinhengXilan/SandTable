<ResourceDictionary x:Class="Editor.ControlStyle.ControlStyle"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Editor.ControlStyle">
    <Style TargetType="{x:Type TextBox}" x:Key="TextBoxStyleBase">
        
    </Style>
    <Style TargetType="{x:Type TextBox}" x:Key="{x:Type TextBox}" BasedOn="{StaticResource TextBoxStyleBase}">
        <EventSetter Event="KeyDown" Handler="TextBoxKeyDown"/>
    </Style>
</ResourceDictionary>