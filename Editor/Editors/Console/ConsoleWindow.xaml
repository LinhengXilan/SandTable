<Window x:Class="Editor.Editors.Console.ConsoleWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:Editor.Editors.Console"
        xmlns:utils="clr-namespace:Editor.Utility"
		mc:Ignorable="d"
		Title="ConsoleWindow"
		WindowStyle="None" AllowsTransparency="True"
        MinWidth="640" MinHeight="480">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <local:ConsoleWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="#2C2C2C"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#2C2C2C"/>
        </Style>
        <Style TargetType="Grid">
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       WindowChrome.IsHitTestVisibleInChrome="True"
                       Text="控制台"
                       VerticalAlignment="Center" Margin="5, 0 , 0, 0"
                       MouseLeftButtonDown="MouseDrag"/>
            <Grid Grid.Column="1"
                  WindowChrome.IsHitTestVisibleInChrome="True">

            </Grid>
            <StackPanel Grid.Column="2"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="40" Background="#00FF00"
                        Click="MinimizationButtonClicked"/>
                <Button Width="40" Background="#FFFF88"
                        Click="MaximizationButtonClicked"/>
                <Button Width="40" Background="#FF0000"
                        Click="CloseButtonClicked"/>
            </StackPanel>
        </Grid>
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Source={x:Static utils:Logger.FilteredMessages}}"
                          Margin="5">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type utils:LogMessage}">
                        <DockPanel ToolTip="{Binding Format}">
                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Setter Property="Background" Value="#1C1C1C"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2C2C2C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>

                            <TextBlock Text="{Binding Time, StringFormat=hh:mm:ss}"
                                       Margin="0, 2, 0, 0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static utils:LogMessageType.Error}">
                                                <Setter Property="Foreground" Value="#FF0000"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static utils:LogMessageType.Warning}">
                                                <Setter Property="Foreground" Value="#FF9900"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static utils:LogMessageType.Info}">
                                                <Setter Property="Foreground" Value="#0099FF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="{Binding Message}" Foreground="#FFFFFF"
                                       Margin="5, 2, 0, 2" VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       FontFamily="JetBrains Mono UL, Microsoft YaHei UI"/>
                        </DockPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>