	@file Editors/MainEditor/MainEditorWindow.xaml
	@author LinhengXilan
    @version 0.0.0.27
    @date 2026-7-3
-->
	
<Window x:Class="Editor.Editors.MainEditor.MainEditorWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:Editor.Editors.MainEditor"
		xmlns:detailPanel="clr-namespace:Editor.Editors.DetailPanel"
        xmlns:fileBrowser="clr-namespace:Editor.Editors.FileBrowser"
        xmlns:renderer="clr-namespace:Editor.Editors.Renderer"
        xmlns:objectBrowser="clr-namespace:Editor.Editors.ObjectBrowser"
        mc:Ignorable="d"
		Title="EditorWindow"
		WindowStyle="None" AllowsTransparency="True" 
		MinWidth="640" MinHeight="480">

	<WindowChrome.WindowChrome>
		<WindowChrome CaptionHeight="30"/>
	</WindowChrome.WindowChrome>

    <Window.DataContext>
        <local:MainEditorWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#2C2C2C"/>
        </Style>
        <Style TargetType="Grid">
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
        <Style TargetType="Border">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#AFAFAF"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="DodgerBlue"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="Z"
                    Command="{Binding UndoCommand}"/>
        <KeyBinding Modifiers="Control" Key="Y"
                    Command="{Binding RedoCommand}"/>
        <KeyBinding Modifiers="Control" Key="S"
                    Command="{Binding SaveCommand}"/>
    </Window.InputBindings>
	  
	<Grid Background="#1C1C1C">
		<Grid.RowDefinitions>
			<RowDefinition Height="32"/>
            <RowDefinition Height="30"/>
            <RowDefinition/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
		<Grid Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="32"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
			</Grid.ColumnDefinitions>
			<Image Grid.Column="0"/>
			<Menu Grid.Column="1"
				  Height="30" Margin="1"
				  VerticalAlignment="Center"
                  WindowChrome.IsHitTestVisibleInChrome="True">
                <MenuItem Header="文件">
                    <MenuItem Header="添加层级" Command="{Binding NewLevelButtonCommand}"/>
                    <MenuItem Header="添加实体" Command="{Binding }"/>
                </MenuItem>
                <MenuItem Header="编辑"/>
				<MenuItem Header="项目"/>
				<MenuItem Header="工具"/>
				<MenuItem Header="构建"/>
				<MenuItem Header="插件"/>
				<MenuItem Header="帮助"/>
			</Menu>

            <Label Grid.Column="2" x:Name="TitleLabel"
                   WindowChrome.IsHitTestVisibleInChrome="True"
                   Margin="5, 1, 1, 1"
                   VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                   Content="{Binding CurrentProject.Name, FallbackValue=''}"
                   MouseLeftButtonDown="MouseDrag" MouseDoubleClick="MaximizationButtonClicked"/>
            <Grid Grid.Column="3"
                  WindowChrome.IsHitTestVisibleInChrome="True">

            </Grid>
			<StackPanel Grid.Column="4"
						Orientation="Horizontal" HorizontalAlignment="Right"
                        WindowChrome.IsHitTestVisibleInChrome="True">
				<Button Width="40" Background="#00FF00"
						Click="MinimizationButtonClicked"/>
				<Button Width="40" Background="#FFFF88"
						Click="MaximizationButtonClicked"/>
				<Button Width="40" Background="#FF0000"
						Click="CloseButtonClicked"/>
			</StackPanel>
		</Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal" HorizontalAlignment="Left">

            </StackPanel>
            <ListBox Grid.Column="1"
                     Margin="0, 2, 0, 0"
                     BorderThickness="0">

            </ListBox>
        </Grid>
		<Grid Grid.Row="2"
              Margin="2">
			<Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="100" Width="300"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition MinWidth="100" Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition MinWidth="100" Width="300"/>
			</Grid.ColumnDefinitions>
            
            <Border Grid.Column="0">
                <fileBrowser:FileBrowserView/>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="2"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition MinHeight="100" Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition MinHeight="100" Height="300"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0">
                    <renderer:RendererView/>
                </Border>
                <GridSplitter Grid.Row="1"
                              Height="2"/>
                <Border Grid.Row="2">
                    <objectBrowser:ObjectBrowserView/>
                </Border>
            </Grid>

			<GridSplitter Grid.Column="3"
						  Width="2"/>

            <Border Grid.Column="4">
                <detailPanel:DetailPanelView/>
            </Border>
		</Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="控制台"
                        Height="30" Width="55"
                        Command="{Binding ConsoleButtonClicked}"/>
            </StackPanel>
        </Grid>
	</Grid>
</Window>