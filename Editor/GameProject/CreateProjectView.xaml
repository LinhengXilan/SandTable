<UserControl x:Class="Editor.GameProject.CreateProjectView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:Editor.GameProject"
			 mc:Ignorable="d" Width="800"
			 d:DataContext="{d:DesignInstance Type=local:CreateProjectModel, IsDesignTimeCreatable=True}">
	<UserControl.DataContext>
		<local:CreateProjectModel/>
	</UserControl.DataContext>
	<StackPanel Background="#1F1F1F">
		<ListBox Width="600" Height="263" ItemsSource="{Binding ProjectTemplates}" x:Name="projectTemplateListBox"
		         SelectedIndex="0">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<StackPanel Orientation="Vertical">
						<TextBlock Text="{Binding ProjectType}"/>
						<TextBlock Text="{Binding Description}"/>
					</StackPanel>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
		<StackPanel Height="18" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0, 30, 0, 0">
			<TextBlock Text="项目名称" Width="50"/>
			<TextBox Width="550" Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"/>
		</StackPanel>
	    <StackPanel Height="18" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0, 30, 0, 0">
		    <TextBlock Text="位置" Width="50"/>
		    <TextBox Width="500" Text="{Binding ProjectPath, UpdateSourceTrigger=PropertyChanged}"/>
			<Button Content="浏览" Width="45" Margin="5, 0, 0, 0"/>
	    </StackPanel>
	    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0, 30, 0, 0">
			<Button Content="返回" Width="60" Height="20" IsCancel="True"/>
			<Button Content="创建" Width="60" Height="20" Margin="30, 0, 0, 0" IsDefault="True" IsEnabled="{Binding IsValid}" Click="CreateButtonClicked"/>
		</StackPanel>
		<TextBlock Text="{Binding ErrorMessage}" Margin="30, 5, 30, 0" VerticalAlignment="Center"
		           Foreground="#DDDDDD" Height="16"/>
	</StackPanel>
</UserControl>