<Window x:Class="Editor.GameProject.ProjectBrowserDialog"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:Editor.GameProject"
		mc:Ignorable="d" ResizeMode="NoResize"
		Title="ProjectBrowser" Height="500" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <ToggleButton Content="打开项目" x:Name="openProjectButton" FontSize="20"
                          Click="OnToggleButtonClick" IsChecked="True"/>
            <ToggleButton Content="新建项目" x:Name="createProjectButton" FontSize="20" Margin="10, 0, 0, 0"
                          Click="OnToggleButtonClick" IsChecked="False"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="1" x:Name="browserContent" Background="#1F1F1F">
            <local:OpenProjectView />
			<local:CreateProjectView/>
        </StackPanel>
    </Grid>
</Window>
