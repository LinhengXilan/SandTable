<Page x:Class="Editor.ProjectBrowser.LoadProjectPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	  xmlns:local="clr-namespace:Editor.ProjectBrowser"
	  mc:Ignorable="d" 
	  Title="LoadProjectPage">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="200"/>
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<StackPanel Margin="20" Orientation="Vertical">
			<Button Content="新建项目" Height="30"
					Click="NewProjectButtonClicked"/>
            <Button Content="打开项目" Height="30" Margin="0, 5, 0, 0"
                    Click="OpenProjectButtonClicked" />
		</StackPanel>

		<ListBox Grid.Column="1" Margin="0, 10, 10, 10">

		</ListBox>
	</Grid>
</Page>
