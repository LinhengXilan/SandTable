<UserControl x:Class="Editor.ProjectBrowser.LoadProjectView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Editor.ProjectBrowser"
      mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Margin="10">
            <Button Content="新建项目" Height="30"
                    Command="{Binding NewProjectButtonCommand}"/>
            <Button Content="打开项目" Height="30" Margin="0, 5, 0, 0"
                    Click="OpenProjectButtonClicked"/>
        </StackPanel>

        <ListBox Grid.Column="1" x:Name="ProjectInfoListBox"
                 ItemsSource="{Binding ProjectInfos}"
                 Margin="0, 10, 10, 10">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="2"/>
                    <EventSetter Event="MouseDoubleClick" Handler="ProjectInfoDoubleClicked"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Image Width="32" Height="32"
                               Source="{Binding IconPath}"/>
                        <Grid Margin="5, 0, 0, 0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Height="20"
                                       Text="{Binding Name}"/>
                            <TextBlock Grid.Row="1"
                                       Height="20"
                                       Text="{Binding Path}"/>
                        </Grid>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>