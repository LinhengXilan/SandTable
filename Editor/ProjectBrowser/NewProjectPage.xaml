	@data 2025-5-20
-->
	
<Page x:Class="Editor.ProjectBrowser.NewProjectPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	  xmlns:local="clr-namespace:Editor.ProjectBrowser"
	  mc:Ignorable="d" 
	  Title="NewProjectPage"
	  d:DataContext="{d:DesignInstance Type=local:NewProjectViewModel, IsDesignTimeCreatable=True}">
	<Page.DataContext>
		<local:NewProjectViewModel/>
    </Page.DataContext>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<ListBox Grid.Row="0" Margin="10" ItemsSource="{Binding ProjectTemplates}"
				 x:Name="ProjectTemplateListBox" SelectedIndex="0">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding Type}"/>
						<TextBlock Text="{Binding Description}"/>
					</StackPanel>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
		<StackPanel Grid.Row="1" Orientation="Vertical">
			<Grid Margin="10, 0 10, 0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Margin="5"
					Text="项目名称"/>
				<TextBox Grid.Column="1" Height="20" Margin="10, 0, 0, 0"
                         Text="{Binding ProjectName}"/>
			</Grid>
			<Grid Margin="10, 5, 10, 0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Margin="5"
						   Text="项目路径"/>
				<TextBox Grid.Column="1" Height="20" Margin="10, 0, 0, 0"
                         Text="{Binding ProjectPath}"/>
			</Grid>
		</StackPanel>
		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0, 10, 10, 10">
			<Button Content="返回" Width="80" Height="30" Margin="10, 0, 0, 0"
					Click="ReturnButtonClicked"/>
			<Button Content="创建" Width="80" Height="30" Margin="10, 0, 0, 0"
					Click="CreateButtonClicked"/>
		</StackPanel>
	</Grid>
</Page>