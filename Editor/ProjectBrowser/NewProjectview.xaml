<UserControl x:Class="Editor.ProjectBrowser.NewProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Editor.ProjectBrowser"
             mc:Ignorable="d">
    <Grid Background="#2C2C2C">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox Grid.Row="0"
                 SelectedItem="{Binding ProjectTemplateListBoxSelectedItem, Mode=TwoWay}"
                 ItemsSource="{Binding ProjectTemplates}"
                 Margin="10"
                 SelectedIndex="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="2"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding Type}"
                                   Height="20"/>
                        <TextBlock Text="{Binding Description}"
                                   Height="20"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="1"
                    Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="项目名称" />
                <TextBox Grid.Column="1"
                         Text="{Binding ProjectName}"
                         Margin="10, 0, 0, 0" Height="20"/>
            </Grid>

            <Grid Margin="0, 5, 0, 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="项目路径"/>
                <TextBox Grid.Column="1"
                         Text="{Binding ProjectSavePath}"
                         Height="20" Margin="10, 0, 0, 0"/>
                <Button Grid.Column="2"
                        Content="..." Command="{Binding SelectFolderButtonClickedCommand}"
                        Height="20" Margin="5, 0, 0, 0"/>
            </Grid>

            <Grid Margin="0, 5, 0, 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Background="#2C2C2C"
                           Text="{Binding ErrorMessage}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="返回"
                        Height="30" Margin="10, 0 ,0 ,0"
                        Command="{Binding ReturnButtonClickedCommand}"/>
                <Button Grid.Column="2" Content="创建"
                        Height="30" Margin="5, 0, 0, 0"
                        Command="{Binding CreateButtonClickedCommand}"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>